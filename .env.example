# このファイルはテンプレート。実値は .env.local に書く（.env.local は gitignore 済み）。
# 機密の接続文字列は env_etc.txt(リポ外) を参照。本番は Secret Manager。

# MongoDB Atlas 接続文字列
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGODB_DB=kings

# seed の取り込み元（機密・リポ外の v2 データ。既定は baseball_score_schema/output）
SEED_SOURCE_DIR=../baseball_score_schema/output
